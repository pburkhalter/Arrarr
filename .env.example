# Required
ARRARR_API_KEY=please-change-me
TORBOX_API_KEY=your-torbox-api-key

# Network
ARRARR_LISTEN=:8080
ARRARR_URL_BASE=/sabnzbd

# Paths
LOCAL_VERIFY_BASE=/mnt/torbox
SONARR_VISIBLE_BASE=/torbox
DB_PATH=/data/arrarr.db

# TorBox
TORBOX_BASE_URL=https://api.torbox.app/v1/api
TORBOX_RATE_LIMIT_PER_MIN=200

# Workers
WORKER_POLL_INTERVAL=30s
WORKER_VERIFY_INTERVAL=60s
DISPATCH_INTERVAL=10s
REAP_INTERVAL=5m
JOB_RETENTION_DAYS=7
WORKER_POOL_SIZE=4
MAX_NZB_BYTES=52428800

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
